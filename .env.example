# ============================================================
#  PLANTILLA DE VARIABLES DE ENTORNO
# ============================================================
# Copia este archivo a ".env" para desarrollo LOCAL:
#     cp .env.example .env
#
# El archivo ".env" real esta en .gitignore (NO se sube al repo).
# En Render estas mismas variables se configuran en:
#     Dashboard > tu servicio > Environment
# ============================================================

# ===== BASE DE DATOS (PostgreSQL / Supabase) =====
SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:5432/NOMBRE_BD
SPRING_DATASOURCE_USERNAME=tu_usuario
SPRING_DATASOURCE_PASSWORD=tu_password

# ===== JWT =====
# Clave secreta para firmar los tokens. Debe ser larga (>= 32 caracteres
# para HS256). Genera una aleatoria, NO uses esta de ejemplo.
TOKEN_JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_y_aleatoria

# ===== JPA (opcional) =====
# En produccion se recomienda "validate" o "none" en vez de "update".
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ===== SWAGGER (opcional) =====
# Pon "false" en produccion si no quieres exponer la documentacion.
SPRINGDOC_ENABLED=true

# ===== HELPER DE DESARROLLO (opcional) =====
# Habilita el endpoint publico /dev/hash para generar hashes BCrypt.
# Mantenlo en "false" en produccion. Actívalo solo cuando lo necesites.
DEV_HELPER_ENABLED=false
